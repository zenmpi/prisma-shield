datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int     @id @default(autoincrement())
  email     String
  email_idx String?
  ssn       String?
  ssn_idx   String?
  name      String
  tenantId  String
  role      String  @default("user")
}
